# ShadowOS Environment Variables

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Email sending (Gmail App Password)
SENDER_EMAIL=your_email@gmail.com
SENDER_APP_PASSWORD=your_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Database
DB_PATH=shadowos.db

# Agent config
MAX_PROSPECTS_PER_RUN=30
DEFAULT_NICHE=fitness coaches
FOLLOWER_MIN=10000
FOLLOWER_MAX=100000
